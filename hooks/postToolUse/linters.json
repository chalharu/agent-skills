{
  "tools": [
    {
      "id": "markdownlint-fix",
      "command": "markdownlint-cli2",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "markdownlint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "markdownlint-cli2",
        "--fix"
      ]
    },
    {
      "id": "markdownlint-check",
      "command": "markdownlint-cli2",
      "args": []
    },
    {
      "id": "markdownlint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "markdownlint-cli2"
      ]
    },
    {
      "id": "biome-check-write",
      "command": "biome",
      "args": [
        "check",
        "--write"
      ]
    },
    {
      "id": "biome-check-write-npx",
      "command": "npx",
      "args": [
        "--yes",
        "@biomejs/biome",
        "check",
        "--write"
      ]
    },
    {
      "id": "biome-check",
      "command": "biome",
      "args": [
        "check"
      ]
    },
    {
      "id": "biome-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "@biomejs/biome",
        "check"
      ]
    },
    {
      "id": "oxlint-fix",
      "command": "oxlint",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "oxlint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "oxlint",
        "--fix"
      ]
    },
    {
      "id": "oxlint-check",
      "command": "oxlint",
      "args": []
    },
    {
      "id": "oxlint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "oxlint"
      ]
    },
    {
      "id": "eslint-fix",
      "command": "eslint",
      "args": [
        "--fix"
      ]
    },
    {
      "id": "eslint-fix-npx",
      "command": "npx",
      "args": [
        "--yes",
        "eslint",
        "--fix"
      ]
    },
    {
      "id": "eslint-check",
      "command": "eslint",
      "args": []
    },
    {
      "id": "eslint-check-npx",
      "command": "npx",
      "args": [
        "--yes",
        "eslint"
      ]
    }
  ],
  "pipelines": [
    {
      "id": "markdown",
      "matcher": [
        "\\.(?:md|markdown)$"
      ],
      "steps": [
        {
          "tools": [
            "markdownlint-fix",
            "markdownlint-fix-npx"
          ]
        },
        {
          "tools": [
            "markdownlint-check",
            "markdownlint-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "Markdown linter reported unresolved issues:"
        }
      ]
    },
    {
      "id": "scripts",
      "matcher": [
        "\\.(?:[cm]?[jt]s|[jt]sx)$"
      ],
      "steps": [
        {
          "tools": [
            "biome-check-write",
            "biome-check-write-npx"
          ]
        },
        {
          "tools": [
            "oxlint-fix",
            "eslint-fix",
            "eslint-fix-npx",
            "oxlint-fix-npx"
          ]
        },
        {
          "tools": [
            "biome-check-write",
            "biome-check-write-npx"
          ]
        },
        {
          "tools": [
            "biome-check",
            "biome-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "Biome reported unresolved issues:"
        },
        {
          "tools": [
            "oxlint-check",
            "eslint-check",
            "eslint-check-npx",
            "oxlint-check-npx"
          ],
          "reportFailure": true,
          "failureLabel": "JavaScript/TypeScript linter reported unresolved issues:"
        }
      ]
    }
  ]
}
